async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text(
        "🧠 Привет! Я философский бот.\n\n"
        "/random — случайная притча\n"
        "/help — помощь"
    )

async def help_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text(
        "🤖 **Философский бот**\n\n"
        "/start — приветствие\n"
        "/help — эта справка\n"
        "/random — случайная притча",
        parse_mode=ParseMode.MARKDOWN
    )

async def random_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    text = random.choice(ALL_TEXTS)
    await update.message.reply_text(text, parse_mode=ParseMode.MARKDOWN)

async def handle_message(update: Update, context: ContextTypes.DEFAULT_TYPE):
    # Быстрые ответы (без загрузки процессора)
    quick_answers = [
        "Хм...", "Мудро.", "Интересно...", "/random",
        "Подумай ещё.", "Философский вопрос."
    ]
    await update.message.reply_text(random.choice(quick_answers))

def main():
    # Оптимизированные настройки
    app = Application.builder()\
        .token(TOKEN)\
        .build()
    
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("help", help_command))
    app.add_handler(CommandHandler("random", random_command))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_message))
    
